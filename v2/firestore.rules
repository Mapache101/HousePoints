rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMicrosoftUser() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == 'microsoft.com';
    }

    function isSchoolEmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^[^@]+@scis-bo\\.com$');
    }

    function accessPath() {
      return /databases/$(database)/documents/artifacts/scis-house-points/public/data/userAccess/$(request.auth.uid);
    }

    function hasAccessDoc() {
      return signedIn() && exists(accessPath());
    }

    function access() {
      return get(accessPath()).data;
    }

    function activeUser() {
      return isMicrosoftUser()
        && isSchoolEmail()
        && hasAccessDoc()
        && access().active == true;
    }

    function isAdmin() {
      return activeUser() && access().roles.admin == true;
    }

    function isCoordinator() {
      return activeUser()
        && (access().roles.coordinator == true || access().roles.admin == true);
    }

    function can(permission) {
      return activeUser()
        && (access().roles.admin == true || access().permissions[permission] == true);
    }

    function isOwnerEmail() {
      return resource.data.teacherEmail == request.auth.token.email;
    }

    function isNewOwnerEmail() {
      return request.resource.data.teacherEmail == request.auth.token.email;
    }

    function safeRankingCreate() {
      return request.resource.data.keys().hasOnly([
        'teacherEmail', 'month', 'ranks', 'timestamp', 'processed',
        'sourceApp', 'schemaVersion'
      ])
      && request.resource.data.teacherEmail == request.auth.token.email
      && request.resource.data.processed == false
      && request.resource.data.month is string
      && request.resource.data.ranks is map;
    }

    function safeReflectionCreate() {
      return request.resource.data.keys().hasOnly([
        'type', 'studentId', 'studentName', 'grade', 'house', 'reason',
        'customReason', 'subject', 'teacherEmail', 'timestamp', 'status',
        'pointDeduction', 'sourceApp', 'schemaVersion'
      ])
      && request.resource.data.teacherEmail == request.auth.token.email
      && request.resource.data.status == 'pending'
      && request.resource.data.house in ['centaurs', 'pegasus', 'titans', 'unicorns'];
    }

    match /artifacts/scis-house-points/public/data/houseTotals/{houseId} {
      allow read: if true;
      allow write: if false;
    }

    match /artifacts/scis-house-points/public/data/rankings/{rankingId} {
      allow create: if can('canSubmitPoints') && safeRankingCreate();
      allow read: if isCoordinator() || isAdmin() || (activeUser() && isOwnerEmail());
      allow update: if can('canSubmitPoints')
        && isOwnerEmail()
        && resource.data.processed == false
        && request.resource.data.teacherEmail == resource.data.teacherEmail
        && request.resource.data.processed == false
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'month', 'ranks', 'timestamp', 'sourceApp', 'schemaVersion'
        ]);
      allow delete: if isAdmin()
        || (can('canSubmitPoints') && isOwnerEmail() && resource.data.processed == false);
    }

    match /artifacts/scis-house-points/public/data/students/{studentId} {
      allow read: if activeUser();
      allow create, update, delete: if can('canManageStudents');
    }

    match /artifacts/scis-house-points/public/data/active_reflections/{reflectionId} {
      allow create: if can('canGiveAR') && safeReflectionCreate();
      allow read: if isCoordinator() || isAdmin() || (activeUser() && isOwnerEmail());
      allow update, delete: if false;
    }

    match /artifacts/scis-house-points/public/data/attendance/{attendanceId} {
      allow create: if can('canSubmitAttendance') && isNewOwnerEmail();
      allow read: if isAdmin() || isCoordinator() || (activeUser() && isOwnerEmail());
      allow update, delete: if false;
    }

    match /artifacts/scis-house-points/public/data/scheduled_tests/{testId} {
      allow read: if activeUser();
      allow create: if can('canManageCalendar') && isNewOwnerEmail();
      allow delete: if isAdmin() || (can('canManageCalendar') && isOwnerEmail());
      allow update: if false;
    }

    match /artifacts/scis-house-points/public/data/publicScheduledTests/{testId} {
      allow read: if true;
      allow write: if false;
    }

    match /artifacts/scis-house-points/public/data/publicMetadata/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /artifacts/scis-house-points/public/data/userAccess/{uid} {
      allow read: if activeUser() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /artifacts/scis-house-points/public/data/accessInvites/{inviteId} {
      allow read, write: if false;
    }

    match /artifacts/scis-house-points/public/data/settings/{docId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /artifacts/scis-house-points/public/data/auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
